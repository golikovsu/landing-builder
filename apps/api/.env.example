NODE_ENV=development
PORT=4000

# PostgreSQL (Supabase)
DATABASE_URL="postgresql://user:password@localhost:5432/landing_dev"

# JWT
JWT_SECRET="change-me-to-a-long-random-access-secret"
JWT_REFRESH_SECRET="change-me-to-a-long-random-refresh-secret"

# CORS — comma-separated origins
CORS_ORIGIN="http://localhost:3000"

# AWS S3 / Cloudflare R2 (media uploads)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_ENDPOINT=""
